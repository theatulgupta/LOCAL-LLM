# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_TITLE=Local LLM Server
API_VERSION=1.0.0

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/server.log

# Server
DEBUG=false
MAX_TIMEOUT=300
MAX_PROMPT_LENGTH=4096
